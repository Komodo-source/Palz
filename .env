# ── Supabase storage URL (for getting uploaded file URLs) ──
EXPO_PUBLIC_SUPABASE_URL=https://kcglwtoegceicruwmxzo.supabase.co

# ── Debug mode (shows detailed error messages) ──
EXPO_PUBLIC_DEBUG=true
